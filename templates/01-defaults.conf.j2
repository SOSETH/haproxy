# Managed by ansible (role: haproxy)
# DO NOT EDIT!

global
	log /dev/log	local0 notice
	log /dev/log	local1 notice
{% if haproxy_chroot %}
	chroot /var/lib/haproxy
{% endif %}
	stats socket {{ haproxy_admin_socket }} mode 660 level admin
	stats timeout 30s
	user haproxy
	group haproxy
	daemon

	# Default SSL material locations
	ca-base /etc/ssl/certs
	crt-base /etc/ssl/private

	maxconn {{ haproxy_maxconn }}
	tune.h2.initial-window-size 1048576

  # Get latest config from
  #  https://ssl-config.mozilla.org
  # intermediate configuration
  ssl-default-bind-curves {{ haproxy_ssl_bind_curves }}
  ssl-default-bind-ciphers {{ haproxy_ssl_bind_ciphers }}
  ssl-default-bind-ciphersuites {{ haproxy_ssl_bind_ciphersuites}}
  ssl-default-bind-options {{ haproxy_ssl_bind_options }}

  ssl-default-server-ciphers {{ haproxy_ssl_server_ciphers }}
  ssl-default-server-ciphersuites {{ haproxy_ssl_server_ciphersuites }}
  ssl-default-server-options {{ haproxy_ssl_server_options }}

  {% if haproxy_use_provided_dhparams %}
  ssl-dh-param-file /etc/haproxy/dh-params.txt
  {% endif %}

	hard-stop-after 90s

{% if haproxy_ssl_dhparams_pem is defined %}
	tune.ssl.default-dh-param 2048
	ssl-dh-param-file {{ haproxy_ssl_dhparams_pem }}
{% endif %}

defaults
	log	global
	mode	http
	option	httplog
	option	dontlognull
	timeout connect 5000
	timeout client  36000000
	timeout server  36000000
	errorfile 400 /etc/haproxy/errors/400.http
	errorfile 403 /etc/haproxy/errors/403.http
	errorfile 408 /etc/haproxy/errors/408.http
	errorfile 500 /etc/haproxy/errors/500.http
	errorfile 502 /etc/haproxy/errors/502.http
	errorfile 503 /etc/haproxy/errors/503.http
	errorfile 504 /etc/haproxy/errors/504.http

listen stats
	bind 127.0.0.1:10001
	mode http
	stats enable
	stats realm Haproxy\ Statistics
	stats uri /stats
	stats auth foo:bar

{% if haproxy_prometheus_exporter %}
frontend metrics
   bind *:10002
   mode http
   http-request use-service prometheus-exporter if { path /metrics }
   no log
{% endif %}
